# Root Environment Variables for Development
# This file is used by docker-compose.yml and deployment scripts
# Copy this file to .env and fill in your actual values
# IMPORTANT: DO NOT commit .env to version control!

# ============================================
# Quick Setup Instructions
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Get API keys from the URLs below
# 3. Replace placeholder values with your actual keys
# 4. Run: docker-compose up --build

# ============================================
# Database (PostgreSQL container)
# ============================================
POSTGRES_PASSWORD=roadtrip_dev

# ============================================
# API Keys (REQUIRED)
# ============================================
# Mapbox API Token (used by Python backend + Java geospatial service)
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.eyJ1Ijoi...
VITE_MAPBOX_TOKEN=pk.eyJ1Ijoi...

# Azure Maps Key (used by Python backend + Java geospatial service)
# Get from: Azure Portal > Azure Maps Account > Authentication
AZURE_MAPS_KEY=your-azure-maps-key-here

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com

# ============================================
# Azure OpenAI (C# AI Service — optional)
# ============================================
# Leave empty to use rule-based fallback parsing
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ============================================
# Security Configuration
# ============================================
# JWT Secret Key - Generate with: openssl rand -hex 32
SECRET_KEY=your-random-secret-key-minimum-32-characters-long

# ============================================
# Azure Deployment (Optional)
# ============================================
# Database password for Azure PostgreSQL
DB_ADMIN_PASSWORD=your-secure-database-password

# ============================================
# Azure OpenAI (Required for AI Service)
# ============================================
# Get from: Azure Portal > Azure OpenAI > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4

# ============================================
# JWT Authentication
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-minimum-32-characters

# ============================================
# Development Settings
# ============================================
# Backend API URL for frontend
VITE_API_URL=http://localhost:8000

# ============================================
# Docker Compose Development
# ============================================
# These are used by docker-compose.dev.yml
# GOOGLE_CLIENT_SECRET is needed for OAuth
GOOGLE_CLIENT_SECRET=your-google-client-secret
