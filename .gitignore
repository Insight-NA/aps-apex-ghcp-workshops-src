# ============================================
# Terraform
# ============================================
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Directory for state files when using workspaces
terraform.tfstate.d/

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# But keep example variable files (safe to commit)
!*.tfvars.example
!*.tfvars.example.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negation (!)
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform lock file (DependencyLockFile)
# Uncomment this if you want to ignore the lock file
# .terraform.lock.hcl

# Backend configuration files with sensitive data
backend.hcl
**/backend.hcl

# Keep example backend files
!backend.hcl.example
!**/backend.hcl.example

# ============================================
# Documentation Archive (historical reference only)
# ============================================
docs_archive/

