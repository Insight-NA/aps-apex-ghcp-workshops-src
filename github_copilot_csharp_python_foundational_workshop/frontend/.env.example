# Frontend Environment Variables
# Copy this file to .env.local for development or .env.production for production builds
# IMPORTANT: DO NOT commit .env.local or .env.production to version control!
#
# Vite exposes environment variables that start with VITE_ to the client bundle.
# Learn more: https://vitejs.dev/guide/env-and-mode.html

# ============================================
# Backend API Configuration
# ============================================
# Local Development:
VITE_API_URL=http://localhost:8000
#
# Azure Production (uncomment and update):
# VITE_API_URL=https://roadtrip-api-hl.azurewebsites.net

# ============================================
# Authentication
# ============================================
# Google OAuth Client ID (REQUIRED)
# Must match the backend GOOGLE_CLIENT_ID
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com

# ============================================
# Map Configuration
# ============================================
# Mapbox Public Access Token (REQUIRED)
# Get from: https://account.mapbox.com/access-tokens/
# Note: This is a PUBLIC token - only use tokens with URL restrictions
VITE_MAPBOX_TOKEN=pk.eyJ1Ijoi...

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable development/debug features
VITE_ENABLE_MOCK_AUTH=false
VITE_DEBUG_MODE=false
