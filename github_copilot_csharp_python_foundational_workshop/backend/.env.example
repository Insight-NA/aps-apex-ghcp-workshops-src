# Backend Environment Variables
# Copy this file to .env and fill in your actual values
# IMPORTANT: DO NOT commit .env to version control!

# ============================================
# Database Configuration
# ============================================
# For local development (SQLite):
# DATABASE_URL=sqlite:///./trips.db
#
# For Azure production (PostgreSQL):
DATABASE_URL=postgresql://user:password@server.postgres.database.azure.com:5432/dbname?sslmode=require

# ============================================
# External API Keys
# ============================================
# Mapbox API Token (REQUIRED)
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.eyJ1Ijoi...

# Azure Maps Key (REQUIRED for POI search)
# Get from: Azure Portal > Azure Maps Account > Authentication
AZURE_MAPS_KEY=your-azure-maps-key-here

# Google OAuth Client ID (REQUIRED for authentication)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com

# Google Gemini API Key (OPTIONAL - for AI vehicle spec parsing)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ============================================
# Security Configuration
# ============================================
# JWT Secret Key (REQUIRED)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-random-secret-key-minimum-32-characters-long

# JWT Algorithm (default: HS256)
ALGORITHM=HS256

# JWT Expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Development:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production (uncomment and update):
# ALLOWED_ORIGINS=https://your-frontend.azurestaticapps.net,https://your-custom-domain.com

# ============================================
# Azure Deployment (Optional)
# ============================================
# Used by deployment scripts
DB_ADMIN_PASSWORD=your-secure-database-password
