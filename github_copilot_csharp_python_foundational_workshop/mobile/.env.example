# Environment Configuration for Mobile App
# Copy this file to .env and fill in your actual values

# Backend API URL
# Local development: http://localhost:8000
# Production: https://your-backend-api.azurewebsites.net
VITE_API_URL=http://localhost:8000

# Google OAuth Client IDs
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
# You need separate client IDs for each platform

# Expo Client ID (for development with Expo Go)
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-expo-client-id.apps.googleusercontent.com

# iOS Client ID (for standalone iOS app)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android Client ID (for standalone Android app)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Web Client ID (for backend verification)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Google Maps API Key (for Android)
# Get this from Google Cloud Console: https://console.cloud.google.com/google/maps-apis
# Enable Maps SDK for Android and iOS
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mapbox Token (for map display)
# Get this from Mapbox: https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-token
